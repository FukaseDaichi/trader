# LINE Messaging API credentials
# https://developers.line.biz/console/ で取得
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=your_user_id_here
TRADER_DASHBOARD_URL=https://fukasedaichi.github.io/trader/

# Data source fallback (optional)
TRADER_YF_FALLBACK_ENABLED=true
TRADER_DATA_STALE_OPEN_DAYS=0
TRADER_DATA_HTTP_TIMEOUT_SEC=20

# KPI gate (optional)
TRADER_KPI_GATE_ENABLED=true
TRADER_BT_COST_BPS=10.0
TRADER_BT_SLIPPAGE_BPS=5.0
TRADER_BT_ALLOW_SHORT=false
TRADER_KPI_MIN_CAGR=0.03
TRADER_KPI_MAX_DRAWDOWN=0.25
TRADER_KPI_MIN_EXPECTANCY=0.0001
TRADER_KPI_MIN_SHARPE=0.20
TRADER_KPI_MIN_TRADES=10

# Signal threshold auto-optimization (optional)
TRADER_AUTO_THRESHOLD_ENABLED=true
TRADER_AUTO_THRESHOLD_OBJECTIVE=expectancy
TRADER_AUTO_THRESHOLD_MIN_TRADES=8
TRADER_AUTO_THRESHOLD_MIN_GAP=0.05

# --- Phase 0: 計測基盤（Neon Postgres）---
# Neon の接続文字列。未設定なら DB 書き込みは skip され、従来どおり JSON だけ出力する。
DATABASE_URL=
# DB 書き込みの有効/無効（false で完全に無効化）。
TRADER_DB_ENABLED=true
# DB 不通時のフォールバックキュー出力先。
TRADER_DB_FALLBACK_DIR=data/outbox
# DB 接続タイムアウト秒。
TRADER_DB_WRITE_TIMEOUT_SEC=15
# DB サイズ警告のしきい値（MB）。超過で performance_summary.json に警告フラグ。
TRADER_DB_STORAGE_WARN_MB=400

# --- Phase 1: シグナル品質 ---
# 日次推論モード。auto=保存済みモデルがあれば推論・無ければ legacy 学習にフォールバック。
# legacy=毎日ゼロ学習 + 旧翌日二値ラベル（即時 rollback 用）。phase1=保存済みモデル必須。
TRADER_MODEL_MODE=auto
# 予測ホライズン（営業日）。主軸は 5。
TRADER_TARGET_HORIZON_DAYS=5
# ラベル方式。triple_barrier|vol_norm|binary_1d。
TRADER_LABEL_MODE=triple_barrier
# トリプルバリアの利確/損切り幅（ATR 倍）と時間バリア（営業日）。
TRADER_TB_TP_ATR=1.5
TRADER_TB_SL_ATR=1.0
TRADER_TB_MAX_DAYS=5
# 確率較正。isotonic|none。
TRADER_CALIBRATION_MODE=isotonic
# マクロ/レジーム特徴量の有効/無効。
TRADER_MACRO_FEATURES_ENABLED=true
# モデル artifact の保存先と active ポインタ。
TRADER_MODEL_DIR=data/models
TRADER_MODEL_ACTIVE_FILE=data/models/active_model.json
# 較正に必要な最小 OOS 行数（下回ると uncalibrated）。
TRADER_MIN_CALIBRATION_ROWS=60
# ドリフト検知のしきい値。
TRADER_DRIFT_MIN_OUTCOMES=30
TRADER_DRIFT_MIN_IC=-0.02
TRADER_DRIFT_MAX_BRIER=0.30
TRADER_DRIFT_MAX_PSI=0.25

# --- Phase 2: クロスセクション + ポートフォリオ ---
TRADER_PORTFOLIO_ENABLED=false
TRADER_PORTFOLIO_MODE=shadow        # shadow|active
TRADER_UNIVERSE_TARGET_SIZE=40
TRADER_CS_MODEL_ACTIVE_FILE=data/models/active_cs_model.json
TRADER_CS_MIN_UNIVERSE=30
TRADER_CS_OBJECTIVE=ranker          # ranker|regression
TRADER_CS_TOP_N=8
TRADER_CS_LABEL_HORIZON_DAYS=5
TRADER_CS_MIN_DAILY_NAMES=20
TRADER_CS_PANEL_LOOKBACK_YEARS=5
TRADER_PORTFOLIO_TARGET_VOL=0.12    # annualized
TRADER_PORTFOLIO_MAX_NAME_WEIGHT=0.20
TRADER_PORTFOLIO_SECTOR_CAP=0.40
TRADER_PORTFOLIO_MAX_GROSS=1.00
TRADER_PORTFOLIO_MIN_WEIGHT=0.03
TRADER_PORTFOLIO_NOTRADE_BAND=0.02
TRADER_PORTFOLIO_MIN_EXPECTED_RET=0.0
TRADER_PORTFOLIO_RISK_OFF_GROSS_MULT=0.50
TRADER_PORTFOLIO_COV_LOOKBACK_DAYS=60
TRADER_PORTFOLIO_BACKTEST_MIN_SHARPE=0.30
TRADER_PORTFOLIO_BACKTEST_MAX_DD=0.25
TRADER_PORTFOLIO_BACKTEST_MIN_IR=0.00
TRADER_PORTFOLIO_BACKTEST_MAX_TURNOVER=0.40

# --- Phase 3: 通知・実績UX ---
# LINE 送信リトライ（429/5xx/接続エラーのみ対象。4xx は即時失敗）
TRADER_NOTIFY_RETRY_MAX=3
TRADER_NOTIFY_RETRY_BASE_SEC=1.0
# 日次ダイジェスト（1通で建玉+差分+レジーム+買い/売り銘柄名+直近実績）
TRADER_NOTIFY_DIGEST_ENABLED=true
# 個別シグナル通知。既定で無効（2026-06-11〜 ダイジェストのみ運用。
# LINE 無料枠 200通/月 対策。個別 push を復活させる場合のみ true）
TRADER_NOTIFY_PER_TICKER_ENABLED=false
# 実績詳細 export の対象期間と信頼性ビン数
TRADER_PERF_HISTORY_DAYS=180
TRADER_PERF_RELIABILITY_BINS=10
